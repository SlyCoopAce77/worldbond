PORT=3001

# Google Translate (optional — app works without it, messages won't auto-translate)
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Cloudinary — get these free at cloudinary.com
# Without these, photos save to local disk (fine for dev, lost on Railway redeploy)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
