PORT=3001
NODE_ENV=development

# ── Bond Platform (persistent features) ──────────────────────────────────────
# PostgreSQL — get a free DB at neon.tech, supabase.com, or Railway
DATABASE_URL=postgresql://user:password@localhost:5432/worldbond

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ── Google Translate ──────────────────────────────────────────────────────────
# Optional — app works without it, messages won't auto-translate
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Free tier at cloudinary.com. Without these, files save to local disk.
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
